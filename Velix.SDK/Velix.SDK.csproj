<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12</LangVersion>
    <RootNamespace>Velix.SDK</RootNamespace>
    <AssemblyName>Velix.SDK</AssemblyName>
    <PackageId>Velix.SDK</PackageId>
    <Version>0.1.0-alpha.1</Version>
    <Authors>VELIX Biometrics</Authors>
    <Description>Official .NET SDK for the VELIX biometric access control platform</Description>
    <PackageTags>velix;biometrics;access-control;facial-recognition</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/VELIX-Biometrics/sdk-velix-csharp</RepositoryUrl>
    <PackageProjectUrl>https://velixbiometrics.com</PackageProjectUrl>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Http.Polly" Version="8.0.0" />
    <PackageReference Include="Polly" Version="8.4.0" />
    <PackageReference Include="Polly.Extensions.Http" Version="3.0.0" />
  </ItemGroup>
</Project>
